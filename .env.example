# ============================================================
# Meraki Travels - Frontend .env.example
# Copiar a .env y completar los valores requeridos.
# ============================================================

# --- Next.js ---
NODE_ENV=production
PORT=3005

# --- API URLs ---
NEXT_PUBLIC_API_URL=https://merakitravelsbackend.prome.works
INTERNAL_API_BASE_URL=http://backend:8080

# --- Database (Prisma - Wallpaper only) ---
DATABASE_URL=postgresql://user:password@db:5432/reservas_db?schema=public

# --- NocoDB (Image assets) ---
NOCODB_BASE_URL=
NOCODB_SHARED_VIEW_ID=
NOCODB_SHARED_VIEW_PWD=

# --- Cloudflare Tunnel (frontend) ---
CLOUDFLARED_FRONTEND_TOKEN=
